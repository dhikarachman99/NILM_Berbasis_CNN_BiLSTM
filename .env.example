# Copy to .env.local (local) or set in Vercel Project → Settings → Environment Variables.
# Never commit real secrets to Git.

# --- Data source ---
NILM_DATA_SOURCE=thingsboard
USE_DUMMY_BLYNK=false

# --- ThingsBoard (server-side only) ---
THINGSBOARD_BASE_URL=https://eu.thingsboard.cloud
THINGSBOARD_ACCESS_TOKEN=your_device_access_token
THINGSBOARD_API_TOKEN=your_tb_api_token_optional
THINGSBOARD_DEVICE_ID=your_device_uuid_optional
THINGSBOARD_USERNAME=
THINGSBOARD_PASSWORD=
THINGSBOARD_KEY_VOLTAGE=tegangan
THINGSBOARD_KEY_CURRENT=arus
THINGSBOARD_KEY_POWER=daya
THINGSBOARD_KEY_ENERGY=kwh
THINGSBOARD_KEY_FREQUENCY=frekuensi
THINGSBOARD_KEY_POWER_FACTOR=power_factor

# --- ML service (host separately, e.g. Render — NOT on Vercel) ---
ML_SERVICE_URL=https://your-ml-service.onrender.com
ML_UPDATE_BLYNK=false

# --- Blynk (optional, if NILM_DATA_SOURCE=blynk) ---
BLYNK_AUTH_TOKEN=
BLYNK_BASE_URL=https://blynk.cloud/external/api

# --- Frontend ---
NEXT_PUBLIC_REFRESH_INTERVAL=3000

# --- Model metadata path (used by /api/model/* routes only) ---
NILM_MODEL_DIR=src/nilm_models_v9
