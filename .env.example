# =============================================================================
# Hugging Face Space (ML service) — set in HF Space Settings → Variables
# =============================================================================
NILM_MODEL_DIR=src/nilm_models_v9
NILM_PRELOAD_MODEL=1
USE_DUMMY_BLYNK=false

THINGSBOARD_BASE_URL=https://eu.thingsboard.cloud
THINGSBOARD_ACCESS_TOKEN=your_device_access_token
THINGSBOARD_API_TOKEN=your_tb_api_token_optional
THINGSBOARD_DEVICE_ID=your_device_uuid_optional
THINGSBOARD_USERNAME=
THINGSBOARD_PASSWORD=
# auto | device_token | api_token | login
# Token tb_* butuh header ApiKey (bukan Bearer) — sudah ditangani di ml_service
THINGSBOARD_AUTH_MODE=auto
THINGSBOARD_KEY_VOLTAGE=tegangan
THINGSBOARD_KEY_CURRENT=arus
THINGSBOARD_KEY_POWER=daya
THINGSBOARD_KEY_ENERGY=kwh
THINGSBOARD_KEY_FREQUENCY=frekuensi
THINGSBOARD_KEY_POWER_FACTOR=power_factor

CORS_ORIGINS=*

# =============================================================================
# GitHub Pages build (GitHub repo → Settings → Secrets and variables)
# Secret: ML_SERVICE_URL = https://yourusername-your-space.hf.space
# =============================================================================
NEXT_PUBLIC_ML_SERVICE_URL=https://your-username-your-space-name.hf.space
NEXT_PUBLIC_USE_DUMMY_BLYNK=false
NEXT_PUBLIC_REFRESH_INTERVAL=3000
NEXT_PUBLIC_BASE_PATH=/your-repo-name

# =============================================================================
# Local dev (.env.local)
# =============================================================================
# NEXT_PUBLIC_ML_SERVICE_URL=http://127.0.0.1:5001
